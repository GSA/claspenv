{
  "name": "claspenv",
  "version": "0.1.0",
  "description": "A command-line utility for managing Google Apps Script Project environments",
  "main": "dist/src/main.js",
  "private": "true",
  "bin": {
    "claspenv": "dist/src/main.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "clasp",
    "google-apps-script",
    "environment",
    "deployment"
  ],
  "author": "Anthony Peluso",
  "dependencies": {
    "arg": "^5.0.2",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.20",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.1.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0"
  },
  "files": [
    "dist/**/*"
  ]
}
